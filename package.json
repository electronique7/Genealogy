{
  "name": "genealogy-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon --exec 'node --experimental-sqlite' server/index.js",
    "client": "cd client && npm run dev",
    "import": "node --experimental-sqlite scripts/import-gedcom.js \"./reinsel (6).ged\" genealogy.db"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0"
  }
}
